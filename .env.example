# ============================================
# OWASP GraphGuard Configuration
# Copy to .env and fill in values
# ============================================

# --- Langfuse Observability (Required for Phase 1) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Use https://us.cloud.langfuse.com for US region
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Augment / Auggie SDK (Required for Phase 4+) ---
# Get your token by running: auggie token print
# Copy the full JSON token (RECOMMENDED method):
AUGMENT_SESSION_AUTH={"accessToken":"your-token-here","tenantURL":"https://your-tenant.api.augmentcode.com/","scopes":["read","write"]}
#
# Alternative: Separated credentials (less recommended)
# AUGMENT_API_TOKEN=your-access-token-here
# AUGMENT_API_URL=https://your-tenant.api.augmentcode.com/

# --- LLM Provider (Required for Phase 4+) ---
# Anthropic Claude is the primary LLM for security analysis
ANTHROPIC_API_KEY=sk-ant-...
# Model selection (defaults to claude-sonnet-4-5-20250929)
# LLM_MODEL=claude-sonnet-4-5-20250929

# --- Target Repository ---
WORKSPACE_ROOT=./nodejs-goof

# --- Application ---
NODE_ENV=development
LOG_LEVEL=debug
